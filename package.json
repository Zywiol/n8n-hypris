{
	"name": "n8n-nodes-hypris-api",
	"version": "0.1.32",
	"description": "n8n node for Hypris - enterprise workflow and database management platform",
	"license": "MIT",
	"homepage": "https://github.com/Zywiol/n8n-hypris",
	"repository": {
		"type": "git",
		"url": "https://github.com/Zywiol/n8n-hypris.git"
	},
	"keywords": [
		"n8n-community-node-package",
		"hypris"
	],
	"author": {
		"name": "Dawid Zywica",
		"email": "dawid.zywica@hypris.com"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && cp nodes/Hypris/hypris.svg dist/nodes/Hypris/ && cp nodes/Hypris/hypris.svg dist/credentials/",
		"build:watch": "tsc --watch"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HyprisApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Hypris/Hypris.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
